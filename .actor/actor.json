{
  "actorSpecification": 1,
  "name": "ccobb-inmate-scraper",
  "title": "Ccobb Inmate Scraper",
  "description": "Scrapes Cobb County inmate records. Supports single name or batch names array.",
  "version": "0.1",
  "input": {
    "title": "Input",
    "type": "object",
    "schemaVersion": 1,
    "properties": {
      "name": {
        "title": "Single Name",
        "type": "string",
        "description": "Single inmate name to search (legacy mode)",
        "editor": "textfield"
      },
      "names": {
        "title": "Batch Names",
        "type": "array",
        "description": "Array of name objects for batch mode: [{name, original_name}]",
        "editor": "json"
      },
      "soid": {
        "title": "SOID",
        "type": "string",
        "description": "Inmate SOID number",
        "editor": "textfield"
      },
      "serial": {
        "title": "Serial",
        "type": "string",
        "description": "Serial number",
        "editor": "textfield"
      },
      "mode": {
        "title": "Search Mode",
        "type": "string",
        "description": "Search mode — use Inquiry",
        "editor": "textfield",
        "default": "Inquiry"
      },
      "proxyUsername": {
        "title": "Proxy Username",
        "type": "string",
        "editor": "textfield"
      },
      "proxyPassword": {
        "title": "Proxy Password",
        "type": "string",
        "editor": "textfield"
      },
      "proxyList": {
        "title": "Proxy List",
        "type": "array",
        "description": "Array of proxy addresses host:port",
        "editor": "json"
      }
    },
    "required": []
  }
}
